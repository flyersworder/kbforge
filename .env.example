# Copy to .env (which is gitignored) and fill in real values.
# These are read by the optional LLM synthesizer: pip install "kbforge[llm]".

# OpenRouter API key. OpenRouter is used as an OpenAI-compatible gateway, so it
# rides the same code path as a self-hosted LiteLLM gateway.
OPENROUTER_API_KEY=

# Optional: point the synthesizer at a self-hosted LiteLLM gateway instead.
# KBFORGE_LLM_API_BASE=https://your-litellm-gateway.example/v1
# KBFORGE_LLM_API_KEY=your-gateway-master-key
